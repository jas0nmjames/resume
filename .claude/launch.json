{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Resume (full site)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "Billboard",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "billboard", "--listen", "3001"],
      "port": 3001
    },
    {
      "name": "Resume (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
